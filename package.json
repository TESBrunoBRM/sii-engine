{
  "name": "sii-engine",
  "version": "0.1.0",
  "description": "Motor de Facturación Electrónica SII para Chile — librería TypeScript modular",
  "author": "",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "fast-xml-parser": "^5.2.5",
    "form-data": "^4.0.5",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.0.1"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.2",
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.11",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6"
  }
}
